# 复制为 .env 后填写真实值（.env 已在 .gitignore 中，勿提交密钥）
# cp .env.example .env

# 阿里云 DashScope（通义），用于默认模型、Embedding、ReMe 长期记忆等
DASHSCOPE_API_KEY=

# 爱数 Access Token
AS_TOKEN=

# 可选：走 LiteLLM 代理时（见 agents/baseagent.py）
# LITELLM_KEY=

# 可选：关闭 ReMe 长期记忆（1 / true / yes）
# DISABLE_REME_LONG_TERM_MEMORY=

# ReMe 长期记忆：`reme-ai` 已列入 requirements.txt。若仍报 reme_ai ImportError，请用「运行 server 的同一解释器」自检：
#   python -m pip install -U reme-ai
#   python -c "import reme_ai; print(reme_ai.__file__)"
